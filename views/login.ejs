<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen bg-gray-100 flex items-center justify-center">
    <div class="max-w-md w-full p-8 bg-white rounded-2xl shadow-xl">
        <div class="text-center mb-10">
            <h1 class="text-3xl font-extrabold text-green-600">Well Off</h1>
            <p class="text-gray-500 mt-2">ยินดีต้อนรับกลับมา! กรุณาเข้าสู่ระบบ</p>
        </div>
        
        <form action="/api/login" method="POST" class="space-y-6">
            <div>
                <label class="block text-sm font-semibold text-gray-700">ชื่อผู้ใช้งาน (Username)</label>
                <input type="text" name="username" required 
                    class="w-full border-gray-300 border p-3 rounded-lg focus:ring-2 focus:ring-green-500 outline-none transition" 
                    placeholder="ใส่ Username ของคุณ">
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700">รหัสผ่าน (Password)</label>
                <input type="password" name="password" required 
                    class="w-full border-gray-300 border p-3 rounded-lg focus:ring-2 focus:ring-green-500 outline-none transition" 
                    placeholder="••••••••">
            </div>
            
            <button type="submit" 
                class="w-full bg-green-600 text-white font-bold py-3 rounded-xl hover:bg-green-700 shadow-lg transform hover:-translate-y-1 transition">
                🔓 เข้าสู่ระบบ
            </button>
        </form>
        
        <div class="mt-8 text-center border-t pt-6">
            <p class="text-sm text-gray-600">ยังไม่มีบัญชีใช่ไหม? 
                <a href="/register" class="text-green-600 font-bold hover:underline">สมัครสมาชิกที่นี่</a>
            </p>
        </div>
    </div>
</div>