<meta name="viewport" content="width=device-width, initial-scale=1.0">
<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen bg-gray-100 flex items-center justify-center p-4">
    <div class="max-w-md w-full p-6 md:p-8 bg-white rounded-3xl shadow-xl border border-gray-50">
        <div class="text-center mb-8 md:mb-10">
            
            <img src="/uploads/slips/images/logo.png" alt="Welloff System Logo" class="w-24 md:w-28 h-auto mx-auto mb-5 object-contain hover:scale-105 transition-transform duration-300 drop-shadow-md">
            
            <h1 class="text-2xl md:text-3xl font-extrabold text-gray-800">Welloff System</h1>
            <p class="text-gray-500 mt-2 text-sm md:text-base">ยินดีต้อนรับกลับมา! กรุณาเข้าสู่ระบบ</p>
        </div>
        
        <form action="/api/login" method="POST" class="space-y-5 md:space-y-6">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">ชื่อผู้ใช้งาน (Username)</label>
                <input type="text" name="username" required 
                    class="w-full bg-gray-50 border-gray-200 border p-3.5 rounded-xl focus:bg-white focus:ring-2 focus:ring-green-500 outline-none transition" 
                    placeholder="ใส่ Username ของคุณ">
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">รหัสผ่าน (Password)</label>
                <input type="password" name="password" required 
                    class="w-full bg-gray-50 border-gray-200 border p-3.5 rounded-xl focus:bg-white focus:ring-2 focus:ring-green-500 outline-none transition" 
                    placeholder="••••••••">
            </div>
            
            <button type="submit" 
                class="w-full mt-2 bg-green-600 text-white font-bold py-3.5 md:py-4 rounded-xl hover:bg-green-700 shadow-lg shadow-green-200 transform hover:-translate-y-1 transition duration-200">
                🔓 เข้าสู่ระบบ
            </button>
        </form>
        
        <div class="mt-8 text-center border-t border-gray-100 pt-6">
            <p class="text-sm text-gray-600">ยังไม่มีบัญชีใช่ไหม? 
                <a href="/register" class="text-green-600 font-bold hover:text-green-800 transition ml-1">สมัครสมาชิกที่นี่</a>
            </p>
        </div>
    </div>
</div>