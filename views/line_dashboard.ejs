<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>LINE Bot Dashboard - Welloff</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-50">

    <%- include('partials/navbar') %>

    <div class="max-w-7xl mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                <h2 class="text-xl font-bold mb-6 flex items-center text-green-600">
                    <i class="fab fa-line mr-2 text-2xl"></i> เพิ่มกลุ่มไลน์ (LINE OA)
                </h2>
                
                <% if (lineAccounts.length >= user.lineLimit) { %>
                    <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-6">
                        <p class="text-yellow-700 text-sm">⚠️ บัญชีไลน์ของคุณเต็มแล้ว (<%= lineAccounts.length %>/<%= user.lineLimit %>)</p>
                        <a href="/packages" class="text-blue-600 font-bold text-xs hover:underline">อัปเกรดแพ็คเกจเพื่อเพิ่มอีก</a>
                    </div>
                <% } %>

                <form action="/api/line/add" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">ชื่อกลุ่ม (ไว้อ้างอิง)</label>
                        <input type="text" name="groupName" placeholder="เช่น กลุ่มแชร์บ้านคุณนก" required 
                            class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-green-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Group ID (จากบอท)</label>
                        <input type="text" name="groupId" placeholder="Cxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" required 
                            class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-green-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">ลิงก์เข้ากลุ่ม (Group Link)</label>
                        <input type="url" name="groupUrl" placeholder="https://line.me/ti/g/..." 
                            class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-green-500 outline-none">
                    </div>
                    
                    <button type="submit" 
                        <%= lineAccounts.length >= user.lineLimit ? 'disabled' : '' %>
                        class="w-full <%= lineAccounts.length >= user.lineLimit ? 'bg-gray-300 cursor-not-allowed' : 'bg-green-600 hover:bg-green-700' %> text-white font-bold py-3 rounded-xl transition shadow-md">
                        บันทึกบัญชีไลน์
                    </button>
                </form>
            </div>

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 mt-6">
    <h2 class="text-xl font-bold mb-6 flex items-center text-green-600">
        <i class="fas fa-paper-plane mr-2"></i> ตั้งเวลาส่ง (LINE)
    </h2>
    <form action="/api/jobs/add" method="POST" class="space-y-4">
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">เลือกกลุ่มเป้าหมาย</label>
            <select name="accountId" required class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-green-500 outline-none">
                <% lineAccounts.forEach(acc => { %>
                    <option value="<%= acc.id %>"><%= acc.groupName %></option>
                <% }) %>
            </select>
        </div>
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">ข้อความที่ต้องการส่ง</label>
            <textarea name="message" rows="3" placeholder="พิมพ์ข้อความที่ต้องการส่งเข้ากลุ่ม..." required 
                class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-green-500 outline-none"></textarea>
        </div>
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">เวลาที่ต้องการส่ง</label>
            <input type="datetime-local" name="runAt" 
                class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-green-500 outline-none">
        </div>
        <button type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded-xl transition shadow-md">
            ตั้งเวลาส่งข้อความ
        </button>

        <button type="submit" formaction="/api/jobs/send-now" formnovalidate 
            class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 rounded-xl transition shadow-md">
            <i class="fas fa-paper-plane mr-1"></i> ส่งทันที
        </button>
    </form>
</div>

            <div class="lg:col-span-2 bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                <h2 class="text-xl font-bold mb-6 border-b pb-2">📋 กลุ่มไลน์ที่เชื่อมต่อแล้ว</h2>
                
                <% if (lineAccounts.length === 0) { %>
                    <div class="text-center py-10 text-gray-400">
                        <i class="fas fa-layer-group text-5xl mb-4 opacity-20"></i>
                        <p>ยังไม่มีกลุ่มไลน์ในระบบ</p>
                    </div>
                <% } else { %>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <% lineAccounts.forEach(acc => { %>
                            <div class="border p-4 rounded-xl hover:border-green-400 transition bg-gray-50">
                                <div class="flex justify-between items-start">
                                    <div>
                                        <p class="font-bold text-gray-800"><%= acc.groupName %></p>
                                        <p class="text-xs text-gray-500 truncate w-40">ID: <%= acc.groupId %></p>
                                    </div>
                                    <span class="bg-green-100 text-green-700 text-[10px] px-2 py-1 rounded-full font-bold">READY</span>
                                </div>
                                <div class="mt-4 flex space-x-2">
                                    <a href="<%= acc.groupUrl %>" target="_blank" class="text-xs text-blue-600 hover:underline">เปิดลิงก์กลุ่ม</a>
                                    <button class="text-xs text-red-500 hover:underline ml-auto">ลบออก</button>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>

        </div>
    </div>

</body>
</html>