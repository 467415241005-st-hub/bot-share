<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Welloff</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-50 pb-10">

    <%- include('partials/navbar') %>

    <div class="max-w-7xl mx-auto px-4 mt-6">
        <div class="bg-gradient-to-r from-blue-600 to-blue-500 text-white p-6 md:p-8 rounded-2xl shadow-lg flex flex-col sm:flex-row items-center text-center sm:text-left mb-8">
            <div class="bg-white/20 p-4 rounded-xl mb-4 sm:mb-0 sm:mr-6 text-4xl">🤖</div>
            <div>
                <h1 class="text-2xl md:text-3xl font-bold">Bot Share Master</h1>
                <p class="opacity-80 text-sm md:text-base mt-1">ระบบจัดการบอทจองแชร์ (เซิร์ฟเวอร์ส่วนตัว)</p>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-8">
            
            <div class="space-y-6 md:space-y-8">
                <div class="bg-white p-5 md:p-6 rounded-2xl shadow-sm border border-gray-100">
                    <h2 class="text-lg md:text-xl font-bold mb-4 md:mb-6 flex items-center"><i class="fas fa-plus-circle mr-2 text-blue-500"></i> เพิ่มบัญชี Facebook</h2>
                    <form action="/api/accounts/add" method="POST" class="space-y-4">
                        <input type="text" name="fbEmail" placeholder="อีเมล/เบอร์โทร" required class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none">
                        <input type="password" name="fbPassword" placeholder="รหัสผ่าน" required class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none">
                        <textarea name="cookies" placeholder='[{"name":"c_user",...}]' class="w-full border-gray-200 border p-3 rounded-xl h-24 text-xs font-mono focus:ring-2 focus:ring-blue-500 outline-none"></textarea>
                        <button type="submit" class="w-full bg-blue-600 text-white font-bold py-3 rounded-xl hover:bg-blue-700 shadow-md transition">บันทึกบัญชี</button>
                    </form>
                </div>

                <div class="bg-white p-5 md:p-6 rounded-2xl shadow-sm border border-gray-100">
                    <h2 class="text-lg md:text-xl font-bold mb-4 md:mb-6 flex items-center text-blue-600">
                        <i class="fas fa-clock mr-2"></i> ตั้งเวลาจอง (Facebook)
                    </h2>
                    <form action="/api/jobs/add" method="POST" class="space-y-4">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">เลือกบัญชีบอท</label>
                            <select name="accountId" required class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none">
                                <% accounts.forEach(acc => { %>
                                    <option value="<%= acc.id %>"><%= acc.fbEmail %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">ลิงก์โพสต์ที่ต้องการจอง</label>
                            <input type="url" name="targetUrl" placeholder="https://www.facebook.com/..." required 
                                class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none text-sm md:text-base">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">ข้อความที่จะคอมเมนต์</label>
                            <input type="text" name="message" placeholder="เช่น จองครับ, รับครับ" required 
                                class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">เวลาที่ให้บอททำงาน</label>
                            <input type="datetime-local" name="runAt" required 
                                class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                        <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-xl transition shadow-md">
                            ยืนยันการตั้งเวลา
                        </button>
                    </form>
                </div>
            </div>

            <div class="lg:col-span-2 bg-white p-5 md:p-6 rounded-2xl shadow-sm border border-gray-100">
                <h2 class="text-lg md:text-xl font-bold mb-4 md:mb-6 border-b pb-3 text-gray-700">📋 บัญชีบอทที่พร้อมใช้งาน</h2>
                <% if (accounts.length === 0) { %>
                    <div class="text-center py-12 text-gray-400">
                        <i class="fas fa-users-slash text-4xl mb-3 opacity-30"></i>
                        <p>ยังไม่มีบัญชีในระบบ</p>
                    </div>
                <% } else { %>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <% accounts.forEach(acc => { %>
                            <div class="border p-4 rounded-xl flex flex-col sm:flex-row justify-between items-start sm:items-center bg-gray-50 hover:bg-white hover:border-blue-300 transition gap-3">
                                <div class="w-full truncate">
                                    <p class="font-bold text-gray-800 truncate"><%= acc.fbEmail %></p>
                                    <span class="inline-block mt-1 text-[10px] bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-bold">READY</span>
                                </div>
                                <button class="text-red-500 text-sm hover:text-red-700 hover:underline font-medium bg-red-50 sm:bg-transparent px-3 py-1 sm:p-0 rounded-lg w-full sm:w-auto text-center">
                                    <i class="fas fa-trash-alt sm:hidden mr-1"></i>ลบ
                                </button>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>

        </div>
    </div>
</body>
</html>