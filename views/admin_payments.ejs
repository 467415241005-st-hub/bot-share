<script src="https://cdn.tailwindcss.com"></script>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<div class="max-w-4xl mx-auto mt-6 md:mt-10 p-4 md:p-6">
    <h1 class="text-2xl md:text-3xl font-bold mb-6 md:mb-8 text-center md:text-left">ตรวจสอบสลิปโอนเงิน (Admin Only)</h1>
    
    <div class="grid grid-cols-1 gap-6">
        <% payments.forEach(p => { %>
            <div class="bg-white p-4 md:p-6 rounded-xl shadow flex flex-col md:flex-row items-center justify-between border-l-8 border-yellow-400 gap-4">
                <div class="flex flex-col sm:flex-row items-center sm:items-start text-center sm:text-left gap-4 w-full">
                    <img src="<%= p.slipUrl %>" 
                         class="w-32 h-40 sm:w-24 sm:h-32 object-cover rounded border cursor-pointer hover:scale-150 transition origin-center sm:origin-left" 
                         onclick="window.open(this.src)">
                    <div class="mt-2 sm:mt-0">
                        <p class="font-bold text-lg md:text-xl text-blue-600">ยอดโอน: <%= p.amount %> บาท</p>
                        <p class="text-sm text-gray-500 mt-1">โดย: <span class="font-bold text-gray-700"><%= p.user.username %></span></p>
                        <p class="text-xs text-gray-400 mt-2"><%= p.createdAt.toLocaleString() %></p>
                    </div>
                </div>
                <button onclick="approvePayment('<%= p.id %>')" class="w-full md:w-auto bg-green-600 text-white px-6 py-3 md:py-2 rounded-lg font-bold hover:bg-green-700 shadow-md transition whitespace-nowrap">
                    ✅ อนุมัติยอดนี้
                </button>
            </div>
        <% }) %>
    </div>
</div>

<script>
async function approvePayment(id) {
    if(!confirm('ยืนยันว่ายอดเงินเข้าบัญชีเรียบร้อยแล้ว?')) return;
    const res = await fetch('/api/admin/payments/approve', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ paymentId: id })
    });
    if(res.ok) {
        alert('อนุมัติสำเร็จ! เครดิตถูกเพิ่มเข้าบัญชีลูกค้าแล้ว');
        location.reload();
    }
}
</script>