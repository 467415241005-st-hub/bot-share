<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="max-w-4xl mx-auto mt-6 md:mt-10 p-4 md:p-6 mb-16">
    <h1 class="text-2xl md:text-3xl font-bold mb-6 md:mb-8 text-center md:text-left text-gray-800">
        <i class="fas fa-file-invoice-dollar text-blue-600 mr-2"></i> ตรวจสอบสลิปโอนเงิน (Admin)
    </h1>

    <div class="grid grid-cols-1 gap-6">
        <% if (payments.length === 0) { %>
            <div class="text-center py-16 bg-white rounded-3xl shadow-sm border border-gray-100">
                <i class="fas fa-check-circle text-6xl text-green-200 mb-4"></i>
                <p class="text-gray-500 font-medium text-lg">ไม่มีรายการรอตรวจสอบในขณะนี้</p>
                <p class="text-sm text-gray-400 mt-1">ยอดเยี่ยมมาก! คุณเคลียร์งานหมดแล้ว</p>
            </div>
        <% } else { %>
            <% payments.forEach(p => { %>
                <div class="bg-white p-4 md:p-6 rounded-2xl shadow-sm flex flex-col md:flex-row items-center justify-between border-l-8 border-yellow-400 gap-4 transition hover:shadow-md">
                    <div class="flex flex-col sm:flex-row items-center sm:items-start text-center sm:text-left gap-4 w-full">
                        <img src="<%= p.slipUrl %>" 
                             class="w-32 h-40 sm:w-24 sm:h-32 object-cover rounded-xl border-2 border-gray-100 cursor-pointer hover:scale-110 transition origin-center sm:origin-left shadow-sm" 
                             onclick="window.open(this.src)">
                        <div class="mt-2 sm:mt-0">
                            <p class="font-bold text-lg md:text-xl text-blue-600">ยอดโอน: ฿<%= p.amount.toLocaleString() %></p>
                            <p class="text-sm text-gray-500 mt-1">จากผู้ใช้: <span class="font-bold text-gray-800 bg-gray-100 px-2 py-0.5 rounded"><%= p.user.username %></span></p>
                            <p class="text-xs text-gray-400 mt-2"><i class="far fa-clock"></i> <%= p.createdAt.toLocaleString('th-TH') %></p>
                        </div>
                    </div>
                    <button onclick="approvePayment('<%= p.id %>')" class="w-full md:w-auto bg-green-600 text-white px-6 py-3 md:py-3 rounded-xl font-bold hover:bg-green-700 shadow-lg shadow-green-200 transition whitespace-nowrap flex items-center justify-center">
                        <i class="fas fa-check-circle mr-2"></i> อนุมัติยอดนี้
                    </button>
                </div>
            <% }) %>
        <% } %>
    </div>
</div>

<script>
async function approvePayment(id) {
    if(!confirm('ยืนยันว่ายอดเงินเข้าบัญชีเรียบร้อยแล้ว?')) return;
    try {
        const res = await fetch('/api/admin/payments/approve', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ paymentId: id })
        });
        const data = await res.json();
        
        if(data.success) {
            alert('อนุมัติสำเร็จ! เครดิตถูกเพิ่มเข้าบัญชีลูกค้าแล้ว');
            location.reload();
        } else {
            alert('เกิดข้อผิดพลาดในการอนุมัติ');
        }
    } catch (err) {
        alert('ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้');
    }
}
</script>

<%- include('partials/footer') %>