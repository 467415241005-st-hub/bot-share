<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="max-w-4xl mx-auto mt-6 md:mt-10 p-4 md:p-6 mb-16">
    <h1 class="text-2xl md:text-3xl font-bold mb-6 md:mb-8 text-center md:text-left text-gray-800">
        <i class="fas fa-user-shield text-blue-600 mr-2"></i> ตรวจสอบสลิปโอนเงิน (Admin Only)
    </h1>
    
    <div class="grid grid-cols-1 gap-6">
        <% if (payments.length === 0) { %>
            <div class="text-center py-16 bg-white rounded-3xl shadow-sm border border-gray-100">
                <i class="fas fa-check-circle text-6xl text-green-200 mb-4"></i>
                <p class="text-gray-500 font-medium text-lg">ไม่มีรายการรอตรวจสอบ</p>
            </div>
        <% } else { %>
            <% payments.forEach(p => { %>
                <div class="bg-white p-4 md:p-6 rounded-2xl shadow flex flex-col md:flex-row items-center justify-between border-l-8 border-yellow-400 gap-4">
                    <div class="flex flex-col sm:flex-row items-center sm:items-start text-center sm:text-left gap-4 w-full">
                        <img src="<%= p.slipUrl %>" class="w-32 h-40 sm:w-24 sm:h-32 object-cover rounded-xl border cursor-pointer hover:scale-110 transition shadow-sm" onclick="window.open(this.src)">
                        <div>
                            <p class="font-bold text-lg md:text-xl text-blue-600">ยอดโอน: ฿<%= p.amount.toLocaleString() %></p>
                            <p class="text-sm text-gray-500">โดย: <span class="font-bold text-gray-700"><%= p.user.username %></span></p>
                            <p class="text-xs text-gray-400 mt-2"><%= p.createdAt.toLocaleString('th-TH') %></p>
                        </div>
                    </div>
                    <button onclick="approvePayment('<%= p.id %>')" class="w-full md:w-auto bg-green-600 text-white px-6 py-3 rounded-xl font-bold hover:bg-green-700 shadow-lg transition">✅ อนุมัติยอดนี้</button>
                </div>
            <% }) %>
        <% } %>
    </div>
</div>

<script>
async function approvePayment(id) {
    if(!confirm('ยืนยันว่ายอดเงินเข้าบัญชีเรียบร้อยแล้ว?')) return;
    const res = await fetch('/api/admin/payments/approve', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ paymentId: id })
    });
    if(res.ok) {
        alert('อนุมัติสำเร็จ!');
        location.reload();
    }
}
</script>

<%- include('partials/footer') %>