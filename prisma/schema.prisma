generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. ตาราง User (เก็บข้อมูลลูกค้า/แอดมิน)
model User {
  id         String   @id @default(uuid())
  username   String   @unique
  email      String   @unique
  password   String
  credits    Float    @default(0)
  role       String   @default("USER") // USER หรือ ADMIN
  createdAt  DateTime @default(now())

  accounts   BotAccount[]
  lineAccs   LineAccount[]
  payments   Payment[]
}

// 2. ตารางบัญชี Facebook
model BotAccount {
  id         Int      @id @default(autoincrement())
  fbEmail    String   @unique
  fbPassword String
  cookies    String
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  jobs       JobQueue[]
}

// 3. ตารางบัญชี LINE (ใช้ส่งเข้ากลุ่มผ่าน OA)
model LineAccount {
  id         Int     @id @default(autoincrement())
  groupName  String  // ✨ เพิ่มฟิลด์ชื่อกลุ่ม (จากช่องแรกใน UI)
  groupId    String  @unique // ✨ เพิ่มฟิลด์เก็บรหัส C... (จากช่องสองใน UI)
  groupUrl   String? // ลิงก์กลุ่มไลน์ (ตัวที่คุณแก้เป็น Optional แล้ว)
  token      String? // Messaging API Token (ถ้ามีแยกรายบัญชี)
  userId     String
  user       User    @relation(fields: [userId], references: [id])
}

// 4. ตารางคิวงานจองแชร์
model JobQueue {
  id         Int      @id @default(autoincrement())
  targetUrl  String
  message    String
  status     String   @default("PENDING") // PENDING, RUNNING, SUCCESS, FAILED
  runAt      DateTime @default(now())
  accountId  Int
  account    BotAccount @relation(fields: [accountId], references: [id])
}

// 5. ตารางประวัติการเติมเงิน/ส่งสลิป
model Payment {
  id        Int      @id @default(autoincrement())
  amount    Float
  slipUrl   String   // พาธไฟล์รูปสลิป
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}